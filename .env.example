# Visual Crossing Weather API Key
# Get your free key at: https://www.visualcrossing.com/weather-api
VISUAL_CROSSING_API_KEY=YOUR_VISUAL_CROSSING_KEY_HERE

# Google Gemini API Key
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Ticketmaster Discovery API Key
# Get your key at: https://developer.ticketmaster.com/products-and-docs/apis/discovery-api/v2/
TICKETMASTER_API_KEY=YOUR_TICKETMASTER_API_KEY_HERE

# SerpApi key used by Turism /places endpoint
# Get it from https://serpapi.com/dashboard (API Key)
SERPAPI_API_KEY=YOUR_SERPAPI_API_KEY_HERE

# Backward-compatible variable name for places key (optional)
GOOGLE_PLACES_API_KEY=

